 frontend/app/(auth)/login.tsx                 |  17 +-
 frontend/app/room/[id].tsx                    |  42 ++++-
 frontend/src/components/DraggableMember.tsx   | 170 +++++++++++-------
 .../src/components/PrivateMessagesModal.tsx   |  32 +++-
 frontend/src/contexts/AuthContext.tsx         |   6 +-
 6 files changed, 202 insertions(+), 90 deletions(-)

